# Version pins validated together for this POC.
RKE2_VERSION="v1.34.9+rke2r1"
KUBERNETES_VERSION="v1.34.9"
KUBEFLOW_VERSION="26.03.1"
KUSTOMIZE_VERSION="5.8.1"
LOCAL_PATH_PROVISIONER_VERSION="v0.0.32"
SPARK_OPERATOR_VERSION="2.5.1"
PYSPARK_JOBS_IMAGE="docker.io/kubeflowpoc/kubeflow-pyspark-jobs:0.1.0-arm64"
KUBE_PROM_CHART_VERSION="75.15.1"

# Dedicated Multipass cluster. Existing rke2-* VMs are not modified unless
# STOP_OLD_LAB_VMS=true is passed to 01-create-vms.sh.
SERVER_VM="poc-kf-rke2-server"
AGENT_VM="poc-kf-rke2-agent"
UBUNTU_IMAGE="24.04"

# Sized for a 16 GiB Apple Silicon host. The server is tainted so Kubeflow
# application workloads land on the larger agent.
SERVER_CPUS="2"
SERVER_MEMORY="4G"
SERVER_DISK="25G"
AGENT_CPUS="6"
AGENT_MEMORY="10G"
AGENT_DISK="45G"

# Core Kubeflow includes auth, dashboard/profiles, notebooks v1, and Katib.
# Spark Operator, Enterprise Gateway, and PySpark Jobs are installed separately.
KUBEFLOW_PROFILE="core"

# Local access.
KUBEFLOW_LOCAL_PORT="8081"
